{
  "HackerNews": {
    "MaxN": 200,
    "MaxItemFetchConcurrency": 8,
    "Cache": {
      "BestStoriesIdsSeconds": 30,
      "ItemSeconds": 300
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,connectTimeout=300,abortConnect=false",
    "InstanceName": "hn:"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
